rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // SVG files — anyone can read (public sharing), only owner can write
    match /files/{fileId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid;
      allow update, delete: if request.auth != null
                             && resource.data.uid == request.auth.uid;
    }

    // User profile / subscription tier — owner read-only, server writes via Admin SDK
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }

    // Credit balance + token analytics — owner read-only, server writes via Admin SDK
    match /usage/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }
    match /usage/{userId}/{document=**} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }

    // Pricing config — publicly readable, server writes only
    match /config/{document} {
      allow read: if true;
      allow write: if false;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
