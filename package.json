{
  "name": "editsvgcode",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n vite,firebase -c cyan,yellow \"vite\" \"firebase emulators:start --only firestore,auth\"",
    "dev:vite": "vite",
    "build": "tsc && vitest run && vite build",
    "preview": "vite preview",
    "emulators": "firebase emulators:start --only firestore,auth",
    "ship": "tsc && vitest run && vite build && playwright test && firebase deploy",
    "preview:deploy": "tsc && vitest run && vite build && firebase hosting:channel:deploy preview --expires 7d",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@mantine/core": "^7.17.0",
    "@mantine/hooks": "^7.17.0",
    "@monaco-editor/react": "^4.7.0",
    "@tabler/icons-react": "^3.28.1",
    "allotment": "^1.20.2",
    "dompurify": "^3.2.4",
    "firebase": "^11.5.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/dompurify": "^3.2.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.2.1",
    "firebase-tools": "^13.29.1",
    "jsdom": "^29.0.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "typescript": "^5.8.2",
    "vite": "^6.2.2",
    "vitest": "^4.1.0"
  }
}
